@prefix invline:         <http://example.org/invoiceline/> .
@prefix invoice:         <http://example.org/invoice/> .
@prefix media:           <http://example.org/mediatype/> .
@prefix playlist:        <http://example.org/playlist/> .
@prefix track:           <http://example.org/tracks/> .
@prefix person:          <http://example.org/person/> .

# LINDAS-specific namespaces/qnames
