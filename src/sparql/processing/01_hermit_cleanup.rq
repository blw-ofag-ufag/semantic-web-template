PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

DELETE {
    ?s ?p ?o .
    <internal:anonymous-constants> rdf:type rdfs:Datatype .
}
WHERE {
    {
        ?s ?p ?o .
        FILTER(datatype(?o) = <internal:anonymous-constants>)
    }
    UNION
    {
        <internal:anonymous-constants> rdf:type rdfs:Datatype .
    }
}